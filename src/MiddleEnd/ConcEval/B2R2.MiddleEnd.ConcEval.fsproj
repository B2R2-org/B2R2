<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
    <PackageIcon>b2r2-240x240.png</PackageIcon>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>B2R2 concrete evaluation engine.</Description>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="ConcEvalValue.fs" />
    <Compile Include="IMemory.fs" />
    <Compile Include="NonsharableMemory.fs" />
    <Compile Include="SharableMemory.fs" />
    <Compile Include="BinSectionMemory.fs" />
    <Compile Include="Variables.fs" />
    <Compile Include="EvalState.fs" />
    <Compile Include="EvalUtils.fs" />
    <Compile Include="SafeEvaluator.fs" />
    <Compile Include="Evaluator.fs" />
    <Compile Include="ConcStateAccessor.fs" />
    <Compile Include="ConcExecutor.fs" />
    <None Include="..\..\..\LICENSE.md" Pack="true" PackagePath="" />
    <None Include="..\..\..\assets\b2r2-240x240.png" Pack="true" PackagePath="" />
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\BinIR\B2R2.BinIR.fsproj" />
    <ProjectReference Include="..\..\FrontEnd\API\B2R2.FrontEnd.API.fsproj" />
    <ProjectReference Include="..\Executor\B2R2.MiddleEnd.Executor.fsproj" />
  </ItemGroup>

</Project>
